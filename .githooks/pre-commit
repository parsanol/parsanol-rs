#!/bin/bash
#
# Pre-commit hook for Parsanol-rs
# Mirrors the CI checks in .github/workflows/ci.yml
#
# This hook runs the following checks:
# - cargo fmt (format check)
# - cargo clippy (lint with warnings as errors)
# - cargo doc (documentation build)
# - cargo machete (unused dependencies)
# - typos (spell check)
# - cargo semver-checks (API compatibility check)
#
# To install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# To skip all checks temporarily:
#   SKIP_PRECOMMIT=1 git commit -m "..."
#
# Or create a .skip-precommit file in the repo root:
#   touch .skip-precommit

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# ============================================================================
# Skip mechanism
# ============================================================================
if [ -n "$SKIP_PRECOMMIT" ] || [ -f ".skip-precommit" ]; then
    echo -e "${YELLOW}Skipping pre-commit checks (SKIP_PRECOMMIT set or .skip-precommit file exists)${NC}"
    exit 0
fi

echo ""
echo "========================================"
echo "Running pre-commit checks..."
echo "========================================"
echo ""

# Track if any check fails
FAILED=0

# ============================================================================
# 1. Format Check
# ============================================================================
echo -e "${YELLOW}[1/6] Checking format...${NC}"
if cargo fmt --all -- --check; then
    echo -e "${GREEN}âś“ Format check passed${NC}"
else
    echo -e "${RED}âś— Format check failed${NC}"
    echo -e "${YELLOW}  Run 'cargo fmt --all' to fix${NC}"
    FAILED=1
fi
echo ""

# ============================================================================
# 2. Clippy Lint
# ============================================================================
echo -e "${YELLOW}[2/6] Running clippy (default features)...${NC}"
if cargo clippy --all-targets -- -D warnings; then
    echo -e "${GREEN}âś“ Clippy check passed${NC}"
else
    echo -e "${RED}âś— Clippy check failed${NC}"
    FAILED=1
fi
echo ""

# ============================================================================
# 3. Documentation Build
# ============================================================================
echo -e "${YELLOW}[3/6] Building documentation...${NC}"
if RUSTDOCFLAGS="-D warnings" cargo doc --no-deps --all-features; then
    echo -e "${GREEN}âś“ Documentation build passed${NC}"
else
    echo -e "${RED}âś— Documentation build failed${NC}"
    FAILED=1
fi
echo ""

# ============================================================================
# 4. Unused Dependencies
# ============================================================================
echo -e "${YELLOW}[4/6] Checking for unused dependencies...${NC}"
if ! command -v cargo-machete &> /dev/null; then
    echo -e "${RED}âś— cargo-machete not installed${NC}"
    echo -e "${YELLOW}  Install with: cargo install cargo-machete${NC}"
    FAILED=1
elif cargo machete; then
    echo -e "${GREEN}âś“ No unused dependencies${NC}"
else
    echo -e "${RED}âś— Unused dependencies found${NC}"
    echo -e "${YELLOW}  Run 'cargo machete' to see details${NC}"
    FAILED=1
fi
echo ""

# ============================================================================
# 5. Spell Check
# ============================================================================
echo -e "${YELLOW}[5/6] Running spell check...${NC}"
if ! command -v typos &> /dev/null; then
    echo -e "${RED}âś— typos not installed${NC}"
    echo -e "${YELLOW}  Install with: cargo install typos-cli${NC}"
    FAILED=1
elif typos; then
    echo -e "${GREEN}âś“ Spell check passed${NC}"
else
    echo -e "${RED}âś— Spell check failed${NC}"
    echo -e "${YELLOW}  Run 'typos -w' to fix automatically${NC}"
    FAILED=1
fi
echo ""

# ============================================================================
# 6. Semver Check
# ============================================================================
echo -e "${YELLOW}[6/6] Running semver compatibility check...${NC}"
if ! command -v cargo-semver-checks &> /dev/null; then
    echo -e "${RED}âś— cargo-semver-checks not installed${NC}"
    echo -e "${YELLOW}  Install with: cargo install cargo-semver-checks${NC}"
    FAILED=1
elif git rev-parse --verify origin/main &>/dev/null; then
    echo -e "${CYAN}  Comparing against origin/main...${NC}"
    if cargo semver-checks --baseline-rev origin/main 2>&1; then
        echo -e "${GREEN}âś“ Semver check passed${NC}"
    else
        echo -e "${RED}âś— Semver check failed${NC}"
        echo -e "${YELLOW}  If this is intentional (breaking change), bump version in Cargo.toml${NC}"
        FAILED=1
    fi
else
    echo -e "${RED}âś— No origin/main branch found for semver baseline${NC}"
    echo -e "${YELLOW}  Run 'git fetch origin' first${NC}"
    FAILED=1
fi
echo ""

# ============================================================================
# Summary
# ============================================================================
echo "========================================"
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}All pre-commit checks passed!${NC}"
    exit 0
else
    echo -e "${RED}Some pre-commit checks failed!${NC}"
    echo ""
    echo "Please fix the issues above before committing."
    echo ""
    echo "Quick fixes:"
    echo "  cargo fmt --all"
    echo "  cargo clippy --all-targets --fix"
    echo "  typos -w"
    echo ""
    echo "To skip checks temporarily:"
    echo "  SKIP_PRECOMMIT=1 git commit -m \"...\""
    echo "  # or"
    echo "  touch .skip-precommit"
    exit 1
fi
